GROQ_API_KEY=tu_clave_aqui
LLM_MODEL=llama-3.1-8b-instant
LLM_BASE_URL=https://api.groq.com/openai/v1
# Tope de tokens de salida por respuesta del LLM. Si ves respuestas cortadas
# a mitad de una lista/explicación, sube este valor.
LLM_MAX_TOKENS=1024

# Opcional: solo requerida para la tool consultar_estado_ruc (app/tools/ruc.py).
# Token de api.decolecta.com — https://decolecta.gitbook.io/docs/servicios/integrations
# Si falta, la app arranca igual; la tool responde explícitamente que la
# consulta de RUC en tiempo real no está disponible.
RUC_API_KEY=tu_token_aqui
